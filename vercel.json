{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/valeurs-cotees", "destination": "/valeurs-cotees.html" },
    { "source": "/ma",             "destination": "/ma.html" },
    { "source": "/ma-hub",         "destination": "/ma-hub.html" },
    { "source": "/ma-entreprise",  "destination": "/ma-entreprise.html" },
    { "source": "/macro",          "destination": "/macro.html" },
    { "source": "/reglementation", "destination": "/reglementation.html" },
    { "source": "/contech",        "destination": "/contech.html" },
    { "source": "/blog",           "destination": "/blog.html" },
    { "source": "/article",        "destination": "/article.html" },
    { "source": "/entreprise",     "destination": "/entreprise.html" },
    { "source": "/lbo",              "destination": "/lbo.html" },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html" },
    { "source": "/ma-analyse",       "destination": "/ma-analyse.html" },
    { "source": "/ma-risques",       "destination": "/ma-risques.html" },
    { "source": "/ma-valeur",        "destination": "/ma-valeur.html" },
    { "source": "/ma-joint-ventures","destination": "/ma-joint-ventures.html" },
    { "source": "/ma-build-up",      "destination": "/ma-build-up.html" },
    { "source": "/ma-deals",         "destination": "/ma-deals.html" },
    { "source": "/ma-expansion",     "destination": "/ma-expansion.html" },
    { "source": "/ma-ipo",           "destination": "/ma-ipo.html" },
    { "source": "/macro-detail",     "destination": "/macro-detail.html" }
  ]
}
