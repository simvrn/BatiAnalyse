rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Images publiques en lecture
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Tout le reste : authentifié uniquement
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
